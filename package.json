{
  "name": "@ai-dancer/apm",
  "license": "MIT",
  "version": "1.1.0",
  "description": "Agent Package Management - Universal package manager for AI agent skills",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huaxiabuluo/apm.git"
  },
  "homepage": "https://github.com/huaxiabuluo/apm#readme",
  "bugs": {
    "url": "https://github.com/huaxiabuluo/apm/issues"
  },
  "author": "huaxiabuluo <huaxiabuluo@hotmail.com>",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "apm": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "obuild",
    "build:watch": "obuild --watch",
    "ci": "npm run lint && vitest --coverage --passWithNoTests",
    "cov": "vitest --coverage",
    "dev": "node src/cli.ts",
    "lint": "npm run lint:eslint && npm run lint:format",
    "lint:eslint": "eslint .",
    "lint:format": "prettier --check .",
    "publish:experimental": "node scripts/publish-experimental.mjs",
    "prepare": "husky install",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --cache --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --cache --write"
    ],
    "*.{css,less}": [
      "prettier --cache --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --cache --parser=typescript --write"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.18.0",
    "@clack/prompts": "^1.0.0",
    "cli-table3": "^0.6.5",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "simple-git": "^3.30.0",
    "tar": "^7.5.7",
    "undici": "^7.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.3.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.4.0",
    "@types/node": "^20.11.0",
    "@types/tar": "^6.1.11",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.17",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "jest": "^29.4.3",
    "jest-environment-jsdom": "^29.4.3",
    "lint-staged": "^13.0.0",
    "obuild": "^0.4.22",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "install-node": "20"
  },
  "keywords": [
    "cli",
    "agent-skills",
    "skills",
    "ai-agents",
    "claude-code",
    "package-manager",
    "apm"
  ]
}
